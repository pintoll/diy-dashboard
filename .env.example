# FRED (St. Louis Fed) API key — used by the macro-indicators widget.
# Free key: https://fredaccount.stlouisfed.org/apikey
MAIN_VITE_FRED_API_KEY=

# Gemini API key — build-time fallback for the daily-news widget. Normally the
# key is entered at runtime in Settings (stored in settings.json), which takes
# precedence; leave this empty unless you want a baked-in dev fallback.
MAIN_VITE_GEMINI_API_KEY=
