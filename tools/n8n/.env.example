# Copy to .env.local and fill values. .env.local is gitignored.

# --- SSH ---
N8N_SSH_KEY=~/.ssh/your-key.pem
N8N_SSH_USER=ubuntu
N8N_SSH_HOST=your-host-or-ip
N8N_SSH_OPTS=

# --- n8n REST API ---
N8N_URL=https://n8n.your-domain.com
N8N_API_KEY=

# --- n8n internals (SQLite, default DB type) ---
# Container name on the host (e.g. docker-n8n-1). Discoverable via doctor.sh.
N8N_APP_CONTAINER=
# Path inside the container — defaults to /home/node/.n8n/database.sqlite
N8N_SQLITE_PATH=/home/node/.n8n/database.sqlite

# --- App Postgres (the dashboard DB, separate from n8n's storage) ---
# Optional. Only fill if you also need raw SQL on the app's data store.
APP_DB_CONTAINER=
APP_DB_NAME=
APP_DB_USER=
APP_DB_PASSWORD=
