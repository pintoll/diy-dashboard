#!/usr/bin/env bash
# dyd — terminal CLI for diy-dashboard (pomodoro + today's todos).
# Spec: docs/spec/dyd-cli.md. Talks only to the loopback agent API; remote
# access is SSH's job. No build step: bash + python3 + curl (or curl.exe).
set -o pipefail

PROG="dyd"

die_usage() {
  cat >&2 <<'USAGE'
usage:
  dyd                         overview (pomodoro + today + overdue count)
  dyd pomo                    pomodoro status
  dyd pomo <start|pause|stop|skip|reset>
  dyd pomo set <25:5|50:10|100:20|120:30>
  dyd todo                    today's list
  dyd todo overdue            overdue list
  dyd todo backlog            backlog (todos with no planned day)
  dyd todo add "<title>" [-d <date|today|tomorrow|backlog>] [-n <note>]
  dyd todo done <n|id>
  dyd todo move <n|id|b<n>> <date|today|tomorrow|backlog>
  dyd todo use <n|id|->       add a todo to the desk (- clears the desk)
  dyd todo drop <n|id>        remove a todo from the desk
  dyd source                  list data-source connectors
  dyd source list [--group <g>] [--kind <series|events>]
  dyd source show <id>
  dyd source add <json>       add a connector; the app fetches it before saving
  dyd source patch <id> <json>
  dyd source rm <id>
  dyd source test <id>        fetch a stored connector now, print a sample
  dyd source enable <id> | disable <id>
  dyd cred                    list credential names and their pinned hosts
  dyd cred set <name> <host> <secret>
  dyd cred rm <name>
  global: --json              print the raw API response body
USAGE
  exit 1
}

not_running() {
  echo "diy-dashboard is not running" >&2
  exit 2
}

# --- connection resolution -------------------------------------------------
resolve_conn() {
  if [ -n "${DYD_API_FILE:-}" ]; then
    API_FILE="$DYD_API_FILE"
    case "$API_FILE" in
      /mnt/*) CURL="curl.exe" ;;
      *) CURL="curl" ;;
    esac
  else
    local win
    win=$(ls /mnt/c/Users/*/AppData/Roaming/diy-dashboard/agent-api.json 2>/dev/null | head -1)
    if [ -n "$win" ]; then
      API_FILE="$win"; CURL="curl.exe"
    elif [ -f "$HOME/.config/diy-dashboard/agent-api.json" ]; then
      API_FILE="$HOME/.config/diy-dashboard/agent-api.json"; CURL="curl"
    fi
  fi
  if [ -z "${API_FILE:-}" ] || [ ! -f "$API_FILE" ]; then
    not_running
  fi
  { read -r PORT; read -r TOKEN; } < <(python3 - "$API_FILE" <<'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print(d["port"]); print(d["token"])
except Exception:
    pass
PY
)
  [ -n "${PORT:-}" ] && [ -n "${TOKEN:-}" ] || not_running
}

# --- request helper --------------------------------------------------------
# api METHOD PATH [JSON_BODY] -> sets BODY and HTTP_STATUS; exits 2 on refusal.
api() {
  local method="$1" path="$2" body="${3:-}"
  local args=(-s -S -o - -w '\n%{http_code}' -X "$method"
    -H "Authorization: Bearer $TOKEN")
  if [ -n "$body" ]; then
    args+=(-H "Content-Type: application/json" -d "$body")
  fi
  local resp
  resp=$("$CURL" "${args[@]}" "http://127.0.0.1:$PORT$path" 2>/dev/null)
  if [ $? -ne 0 ]; then
    not_running
  fi
  HTTP_STATUS="${resp##*$'\n'}"
  BODY="${resp%$'\n'*}"
}

# api_get_all PATH... -> fills PAR_BODY / PAR_STATUS, one entry per path, in
# argument order. The requests are issued concurrently, so a view built from
# several independent reads costs one round trip of latency instead of N.
# Validation is left to the caller (assign HTTP_STATUS/BODY, call
# api_ok_or_die), because tolerance differs per endpoint.
api_get_all() {
  local dir path i=0 pid failed=0 resp
  local pids=()
  dir=$(mktemp -d) || not_running
  for path in "$@"; do
    "$CURL" -s -S -o - -w '\n%{http_code}' -X GET \
      -H "Authorization: Bearer $TOKEN" \
      "http://127.0.0.1:$PORT$path" > "$dir/$i" 2>/dev/null &
    pids+=("$!")
    i=$((i + 1))
  done
  for pid in "${pids[@]}"; do
    wait "$pid" || failed=1
  done
  PAR_BODY=(); PAR_STATUS=()
  i=0
  for path in "$@"; do
    resp=$(cat "$dir/$i" 2>/dev/null)
    PAR_STATUS+=("${resp##*$'\n'}")
    PAR_BODY+=("${resp%$'\n'*}")
    i=$((i + 1))
  done
  rm -rf "$dir"
  [ "$failed" = 0 ] || not_running
}

api_ok_or_die() {
  case "$HTTP_STATUS" in
    2*) return 0 ;;
    *)
      local msg
      msg=$(printf '%s' "$BODY" | python3 -c 'import json,sys
try: print(json.load(sys.stdin).get("error",""))
except Exception: print("")' 2>/dev/null)
      echo "${PROG}: error: ${msg:-HTTP $HTTP_STATUS}" >&2
      exit 1 ;;
  esac
}

jget() { # jget JSON 'python-expr on d'
  printf '%s' "$1" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(eval(sys.argv[1]))' "$2"
}

json_arg() { # json_arg <text> -> compact JSON on stdout; 1 + message on a syntax error
  # Connector definitions are typed or pasted by hand, so a stray comma is the
  # likeliest failure. Catch it here where the caret position is still useful,
  # rather than shipping it as a bare "not valid JSON" 400.
  local out
  out=$(printf '%s' "$1" | python3 -c '
import json, sys
try:
    print(json.dumps(json.load(sys.stdin)))
except Exception as e:
    print(e, file=sys.stderr); sys.exit(1)' 2>&1) || {
    echo "${PROG}: error: argument is not valid JSON (${out})" >&2
    return 1
  }
  printf '%s' "$out"
}

urlenc() { # group names are free-form and may contain spaces
  printf '%s' "$1" | python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read(), safe=""))'
}

# date_json <today|tomorrow|backlog|YYYY-MM-DD> -> the JSON value for a body's
# "date" field. `backlog` is null on the wire, not a magic string; an unknown
# spec is passed through verbatim so the API rejects it with a useful message.
date_json() {
  SPEC="$1" python3 -c '
import json, os
from datetime import datetime, timedelta
def kst_now():
    try:
        from zoneinfo import ZoneInfo
        return datetime.now(ZoneInfo("Asia/Seoul"))
    except Exception:
        return datetime.now()
spec = os.environ["SPEC"].strip().lower()
if spec == "backlog":
    print("null")
elif spec == "tomorrow":
    print(json.dumps(str((kst_now() + timedelta(days=1)).date())))
elif spec == "today":
    print(json.dumps(str(kst_now().date())))
else:
    print(json.dumps(os.environ["SPEC"]))'
}

# --- formatter (all human output) -----------------------------------------
FORMATTER=$(cat <<'PY'
import json, sys
from datetime import datetime, timedelta

def load(s):
    s = (s or "").strip()
    return json.loads(s) if s else None

def mmss(sec):
    sec = int(sec)
    sign = "-" if sec < 0 else ""
    sec = abs(sec)
    return f"{sign}{sec//60:02d}:{sec%60:02d}"

def worked(sec):
    sec = int(sec)
    return f"{sec//60}m" if sec >= 60 else ""

PHASE = {"work": "work", "shortBreak": "break", "longBreak": "long break"}
def phase_label(p): return PHASE.get(p, p)

def status_word(s):
    if s["overtime"]: return "overtime"
    if s["isRunning"]: return "running"
    if s["remainingSec"] < s["phaseDurationSec"]: return "paused"
    return "idle"

def pomo_line(p):
    if p is None:
        return "pomodoro: unavailable (no widget?)"
    ph = phase_label(p["phase"]); preset = p["presetId"]; done = p["completedPomodoros"]
    ot = p["overtime"]
    if ot:
        return f"{ph} +{mmss(ot['elapsedSec'])} overtime  ({preset}, #{done})"
    return f"{ph} {mmss(p['remainingSec'])} / {mmss(p['phaseDurationSec'])}  {status_word(p)}   ({preset}, #{done})"

def compact(s):
    ph = phase_label(s["phase"])
    if s["overtime"]:
        return f"⏱ {ph} +{mmss(s['overtime']['elapsedSec'])} overtime"
    st = status_word(s)
    sym = {"running": "▶", "paused": "⏸", "idle": "■"}.get(st, "■")
    return f"{sym} {ph} {mmss(s['remainingSec'])} {st}"

def kst_today():
    try:
        from zoneinfo import ZoneInfo
        return datetime.now(ZoneInfo("Asia/Seoul")).date()
    except Exception:
        return datetime.now().date()

# Connector definitions name a credential; they never carry the secret, so there
# is nothing to redact here.
def auth_label(a):
    m = a["mode"]
    if m == "none":
        return "none"
    if m == "query":
        return f"query param {a['param']} (credential {a['credential']})"
    if m == "bearer":
        return f"bearer (credential {a['credential']})"
    if m == "header":
        return f"header {a['header']} (credential {a['credential']})"
    return m

def sample_lines(t, indent):
    for s in (t.get("sample") or []):
        v = s.get("value")
        print(f"{indent}{s['date']}  {s.get('label') if v is None else v}")

def test_block(t):
    # None means the write asked to skip the dry-run, not that it passed.
    if t is None:
        print("test       skipped")
        return
    if not t.get("ok"):
        print(f"test       FAILED: {t.get('error', '')}")
        return
    print(f"test       ok, {t.get('itemCount', 0)} items")
    sample_lines(t, "           ")

def desk_ids(desk):
    # desk body is {"todos": [...]}; every member is marked on the desk.
    return {t["id"] for t in (desk or {}).get("todos", [])}

def today_block(todos, active_ids, date):
    print(f"── today {date} ─────────────")
    if not todos:
        print("  (none)")
        return
    for i, t in enumerate(todos, 1):
        mark = "*" if t["id"] in active_ids else " "
        box = "[x]" if t["done"] else "[ ]"
        w = worked(t["workedSec"])
        line = f"{mark} {i} {box} {t['title']}"
        print(f"{line:<32} {w}".rstrip() if w else line)

mode = sys.argv[1]

if mode == "overview":
    p = load(sys.argv[2]); todos = load(sys.argv[3]); overdue = load(sys.argv[4]); desk = load(sys.argv[5])
    backlog = load(sys.argv[6])
    ids = desk_ids(desk)
    print(pomo_line(p))
    tlist = (todos or {}).get("todos", [])
    today_block(tlist, ids, str(kst_today()))
    n = len((overdue or {}).get("todos", []))
    if n:
        print(f"── overdue: {n} (dyd todo overdue)")
    b = len((backlog or {}).get("todos", []))
    if b:
        print(f"── backlog: {b} (dyd todo backlog)")

elif mode == "todo":
    todos = load(sys.argv[2]); desk = load(sys.argv[3])
    today_block((todos or {}).get("todos", []), desk_ids(desk), str(kst_today()))

elif mode == "overdue":
    overdue = load(sys.argv[2])
    ts = (overdue or {}).get("todos", [])
    if not ts:
        print("no overdue todos")
    else:
        for t in ts:
            box = "[x]" if t["done"] else "[ ]"
            print(f"  {box} {t['title']}   ({t['date']})   {t['id']}")

elif mode == "backlog":
    ts = (load(sys.argv[2]) or {}).get("todos", [])
    if not ts:
        print("backlog is empty")
    else:
        # b<n> is how these are addressed: `dyd todo move b2 today`.
        for i, t in enumerate(ts, 1):
            box = "[x]" if t["done"] else "[ ]"
            w = worked(t["workedSec"])
            line = f"  b{i} {box} {t['title']}"
            print(f"{line:<32} {w}".rstrip() if w else line)

elif mode == "pomo":
    p = load(sys.argv[2])
    if p is None:
        print("pomodoro: unavailable (no widget?)")
    else:
        cycle = f"preset {p['presetId']}, {p['completedPomodoros']} done this cycle"
        print(f"phase      {phase_label(p['phase'])} ({cycle})")
        print(f"timer      {mmss(p['remainingSec'])} remaining / {mmss(p['phaseDurationSec'])}   {status_word(p)}")
        desk = p.get("desk") or []
        if not desk:
            print("desk       (none)")
        else:
            print(f"desk       {desk[0]['title']}")
            for t in desk[1:]:
                print(f"           {t['title']}")
        ot = p["overtime"]
        if ot:
            print(f"overtime   +{mmss(ot['elapsedSec'])} ({'idle' if ot['isIdle'] else 'active'})")
        if p["pendingReview"]:
            print("review     pending — confirm in the app")

elif mode in ("cmdresult", "setresult"):
    d = load(sys.argv[2]); s = d["state"]
    if not d["applied"]:
        print(f"not applied: {d.get('reason','')}")
    print(compact(s))
    if mode == "setresult" and d["applied"]:
        print(f"(reset to a fresh {s['presetId']} work phase)")
    if s["pendingReview"]:
        print("review pending — confirm in the app")

elif mode == "added":
    todos = load(sys.argv[2]); created_id = sys.argv[3]
    # Position prefix: "" for a day list, "b" when the todo landed in the backlog.
    prefix = sys.argv[4] if len(sys.argv) > 4 else ""
    ts = (todos or {}).get("todos", [])
    for i, t in enumerate(ts, 1):
        if t["id"] == created_id:
            print(f"added  {prefix}{i} [ ] {t['title']}   ({t['date'] or 'backlog'})")
            break

elif mode == "todo_line":
    t = load(sys.argv[2])["todo"]
    box = "[x]" if t["done"] else "[ ]"
    print(f"{sys.argv[3]} {box} {t['title']}")

elif mode == "moved":
    t = load(sys.argv[2])["todo"]
    box = "[x]" if t["done"] else "[ ]"
    print(f"moved: {box} {t['title']}   -> {t['date'] or 'backlog'}")

elif mode == "desk_set":
    d = load(sys.argv[2]); ts = (d or {}).get("todos", [])
    print("desk: " + ", ".join(t["title"] for t in ts) if ts else "desk: (empty)")

elif mode == "sources":
    cs = (load(sys.argv[2]) or {}).get("connectors", [])
    if not cs:
        print("no connectors")
    else:
        wid = max(len(c["id"]) for c in cs)
        wgr = max(len(c["group"]) for c in cs)
        for c in cs:
            mark = " " if c["enabled"] else "-"
            print(f"{mark} {c['id']:<{wid}}  {c['kind']:<6}  {c['group']:<{wgr}}  {c['label']}")
        off = sum(1 for c in cs if not c["enabled"])
        if off:
            print(f"({off} disabled, marked -)")

elif mode == "source_show":
    c = load(sys.argv[2])["connector"]
    print(f"id         {c['id']}")
    print(f"kind       {c['kind']}")
    print(f"label      {c['label']}")
    print(f"group      {c['group']}")
    print(f"enabled    {'yes' if c['enabled'] else 'no'}")
    r = c["request"]
    print(f"url        {r['url']}")
    if r.get("query"):
        print("query      " + "  ".join(f"{k}={v}" for k, v in r["query"].items()))
    if r.get("headers"):
        print("headers    " + "  ".join(f"{k}={v}" for k, v in r["headers"].items()))
    print(f"auth       {auth_label(r['auth'])}")
    resp = c["response"]
    bits = [f"items={resp['itemsPath'] or '(root)'}", f"date={resp['datePath']}"]
    if c["kind"] == "series":
        bits.append(f"value={resp['valuePath']}")
        if resp.get("skipValues"):
            bits.append("skip=" + ",".join(resp["skipValues"]))
    elif resp.get("labelPath"):
        bits.append(f"label={resp['labelPath']}")
    print("response   " + "  ".join(bits))
    if c["kind"] == "series":
        print(f"display    {c['display']['unit']}, {c['display']['fractionDigits']} digits")
    if c.get("cacheTtlMs"):
        print(f"cache      {c['cacheTtlMs'] // 1000}s")
    if c.get("meta"):
        print("meta       " + "  ".join(f"{k}={v}" for k, v in c["meta"].items()))

elif mode == "source_write":
    d = load(sys.argv[2]); c = d["connector"]
    state = "enabled" if c["enabled"] else "disabled"
    print(f"saved      {c['id']}  ({c['kind']}, {c['group']}, {state})")
    test_block(d.get("test"))

elif mode == "test_result":
    t = load(sys.argv[2])["test"]
    if not t.get("ok"):
        print(f"FAILED: {t.get('error', '')}")
    else:
        print(f"ok, {t.get('itemCount', 0)} items")
        sample_lines(t, "  ")

elif mode == "creds":
    cs = (load(sys.argv[2]) or {}).get("credentials", [])
    if not cs:
        print("no credentials")
    else:
        w = max(len(c["name"]) for c in cs)
        for c in cs:
            print(f"  {c['name']:<{w}}  {c['allowedHost']}")

elif mode == "cred_set":
    c = load(sys.argv[2])["credential"]
    print(f"set  {c['name']} -> {c['allowedHost']}")
PY
)

fmt() { python3 -c "$FORMATTER" "$@"; }

resolve_id() { # resolve_id <n|b<n>|id> -> sets RESOLVED_ID; returns 1 on bad position.
  # NOTE: sets a global rather than echoing, so callers invoke it directly (not
  # in $(...)). exit inside a command substitution would only end the subshell.
  # `<n>` is a position in today's list, `b<n>` one in the backlog; anything
  # else is taken as an id. A 21-char nanoid that happens to be all digits (or
  # "b" + digits) would be misread, which is not worth guarding at ~1e-17 odds.
  local arg="$1" path="/api/todos" pos="$1" what="today's list"
  case "$arg" in
    b*)
      pos="${arg#b}"
      case "$pos" in
        ''|*[!0-9]*) RESOLVED_ID="$arg"; return 0 ;;  # not b<n>: an id
      esac
      path="/api/todos/backlog"; what="the backlog" ;;
    ''|*[!0-9]*) RESOLVED_ID="$arg"; return 0 ;;  # non-numeric = id
  esac
  api GET "$path"; api_ok_or_die
  local id
  id=$(printf '%s' "$BODY" | python3 -c '
import json, sys
d = json.load(sys.stdin); n = int(sys.argv[1]); ts = d["todos"]
print(ts[n-1]["id"] if 1 <= n <= len(ts) else "")' "$pos")
  if [ -z "$id" ]; then
    echo "${PROG}: no todo at position $arg in $what" >&2
    return 1
  fi
  RESOLVED_ID="$id"
  return 0
}

# --- argument parsing ------------------------------------------------------
ARGS=(); JSON_OUT=0
for a in "$@"; do
  if [ "$a" = "--json" ]; then JSON_OUT=1; else ARGS+=("$a"); fi
done
set -- "${ARGS[@]}"

resolve_conn

# --- commands --------------------------------------------------------------
cmd_overview() {
  # Five independent reads for one screen: issued concurrently, since serially
  # they are five round trips of latency before anything prints.
  api_get_all /api/pomodoro /api/todos /api/todos/overdue /api/desk /api/todos/backlog
  # The pomodoro read is the one allowed to fail (no session yet): a non-2xx
  # there prints an idle timer rather than killing the whole overview.
  local pomo_body=""
  [ "${PAR_STATUS[0]:0:1}" = "2" ] && pomo_body="${PAR_BODY[0]}"
  local i
  for i in 1 2 3 4; do
    HTTP_STATUS="${PAR_STATUS[$i]}"; BODY="${PAR_BODY[$i]}"; api_ok_or_die
  done
  local todos_body="${PAR_BODY[1]}" overdue_body="${PAR_BODY[2]}"
  local desk_body="${PAR_BODY[3]}" backlog_body="${PAR_BODY[4]}"
  if [ "$JSON_OUT" = 1 ]; then
    python3 -c '
import json, sys
def load(s):
    s=(s or "").strip(); return json.loads(s) if s else None
print(json.dumps({
  "pomodoro": load(sys.argv[1]),
  "todos": load(sys.argv[2]),
  "overdue": load(sys.argv[3]),
  "desk": load(sys.argv[4]),
  "backlog": load(sys.argv[5]),
}))' "$pomo_body" "$todos_body" "$overdue_body" "$desk_body" "$backlog_body"
    return
  fi
  fmt overview "$pomo_body" "$todos_body" "$overdue_body" "$desk_body" "$backlog_body"
}

cmd_pomo() {
  if [ $# -eq 0 ]; then
    api GET /api/pomodoro
    if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; [ "${HTTP_STATUS:0:1}" = "2" ] || exit 1; return; fi
    if [ "${HTTP_STATUS:0:1}" = "2" ]; then fmt pomo "$BODY"; else fmt pomo ""; fi
    return
  fi
  local sub="$1"; shift
  case "$sub" in
    start|pause|skip|reset)
      api POST /api/pomodoro/command "$(printf '{"action":"%s"}' "$sub")"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt cmdresult "$BODY" ;;
    stop)
      # Overtime-aware: one user verb; send stop-overtime when overtime is active.
      api GET /api/pomodoro; api_ok_or_die
      local action="stop"
      [ "$(jget "$BODY" 'bool(d.get("overtime"))')" = "True" ] && action="stop-overtime"
      api POST /api/pomodoro/command "$(printf '{"action":"%s"}' "$action")"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt cmdresult "$BODY" ;;
    set)
      [ $# -eq 1 ] || die_usage
      local preset="$1"
      case "$preset" in
        25:5|50:10|100:20|120:30) ;;
        *) echo "${PROG}: preset must be one of 25:5 50:10 100:20 120:30" >&2; exit 1 ;;
      esac
      api POST /api/pomodoro/command "$(printf '{"action":"set-preset","presetId":"%s"}' "$preset")"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt setresult "$BODY" ;;
    *) die_usage ;;
  esac
}

cmd_todo() {
  if [ $# -eq 0 ]; then
    api GET /api/todos
    if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
    api_ok_or_die; local todos_body="$BODY"
    api GET /api/desk; api_ok_or_die
    fmt todo "$todos_body" "$BODY"
    return
  fi
  local sub="$1"; shift
  case "$sub" in
    overdue)
      api GET /api/todos/overdue
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt overdue "$BODY" ;;
    backlog)
      api GET /api/todos/backlog
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt backlog "$BODY" ;;
    add)
      [ $# -ge 1 ] || die_usage
      local title="$1"; shift
      local date="" note=""
      while [ $# -gt 0 ]; do
        case "$1" in
          -d) date="${2:-}"; shift 2 ;;
          -n) note="${2:-}"; shift 2 ;;
          *) die_usage ;;
        esac
      done
      # No -d at all leaves "date" out of the body entirely, which the API reads
      # as today. That is not the same as -d backlog, which sends null.
      local datejson=""
      [ -n "$date" ] && datejson=$(date_json "$date")
      local body
      body=$(TITLE="$title" DATEJSON="$datejson" NOTE="$note" python3 -c '
import json, os
out = {"title": os.environ["TITLE"]}
if os.environ["DATEJSON"]:
    out["date"] = json.loads(os.environ["DATEJSON"])
if os.environ["NOTE"]:
    out["note"] = os.environ["NOTE"]
print(json.dumps(out))')
      api POST /api/todos "$body"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die
      local created_id created_date
      created_id=$(jget "$BODY" 'd["todo"]["id"]')
      created_date=$(jget "$BODY" 'd["todo"]["date"] or ""')
      if [ -z "$created_date" ]; then
        api GET /api/todos/backlog; api_ok_or_die
        fmt added "$BODY" "$created_id" b
      else
        api "GET" "/api/todos?date=$created_date"; api_ok_or_die
        fmt added "$BODY" "$created_id"
      fi ;;
    move)
      # Re-plan a todo: onto a day, or into the backlog (no day at all).
      [ $# -eq 2 ] || die_usage
      resolve_id "$1" || exit 1
      api PATCH "/api/todos/$RESOLVED_ID" "$(printf '{"date":%s}' "$(date_json "$2")")"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt moved "$BODY" ;;
    done)
      [ $# -eq 1 ] || die_usage
      resolve_id "$1" || exit 1
      api PATCH "/api/todos/$RESOLVED_ID" '{"done":true}'
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt todo_line "$BODY" "done:" ;;
    use)
      # Add to the desk (additive); `use -` clears the whole desk.
      [ $# -eq 1 ] || die_usage
      if [ "$1" = "-" ]; then
        api DELETE /api/desk
      else
        resolve_id "$1" || exit 1
        api POST /api/desk "$(printf '{"id":"%s"}' "$RESOLVED_ID")"
      fi
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt desk_set "$BODY" ;;
    drop)
      # Remove a single member from the desk.
      [ $# -eq 1 ] || die_usage
      resolve_id "$1" || exit 1
      api DELETE "/api/desk/$RESOLVED_ID"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt desk_set "$BODY" ;;
    *) die_usage ;;
  esac
}

# Data-source connectors. Writes go through the API's dry-run: the app fetches
# the definition for real before storing it, so `add`/`patch` can take a few
# seconds and a bad path comes back as an error instead of a silent dud card.
cmd_source() {
  local sub="${1:-list}"; [ $# -gt 0 ] && shift
  case "$sub" in
    list)
      local qs=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --group) [ $# -ge 2 ] || die_usage; qs="$qs&group=$(urlenc "$2")"; shift 2 ;;
          --kind) [ $# -ge 2 ] || die_usage; qs="$qs&kind=$(urlenc "$2")"; shift 2 ;;
          *) die_usage ;;
        esac
      done
      local path="/api/connectors"
      [ -n "$qs" ] && path="$path?${qs#&}"
      api GET "$path"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt sources "$BODY" ;;
    show)
      [ $# -eq 1 ] || die_usage
      api GET "/api/connectors/$1"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt source_show "$BODY" ;;
    add)
      [ $# -eq 1 ] || die_usage
      local body; body=$(json_arg "$1") || exit 1
      api POST /api/connectors "$body"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt source_write "$BODY" ;;
    patch)
      [ $# -eq 2 ] || die_usage
      local body; body=$(json_arg "$2") || exit 1
      api PATCH "/api/connectors/$1" "$body"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt source_write "$BODY" ;;
    rm)
      [ $# -eq 1 ] || die_usage
      api DELETE "/api/connectors/$1"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; echo "removed  $1" ;;
    test)
      [ $# -eq 1 ] || die_usage
      api POST "/api/connectors/$1/test"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die
      fmt test_result "$BODY"
      # A reachable app that fetched a broken source is HTTP 200 with ok:false.
      # Exit 1 anyway: the verdict is the whole reason to run this command.
      [ "$(jget "$BODY" 'd["test"]["ok"]')" = "True" ] || exit 1 ;;
    enable|disable)
      [ $# -eq 1 ] || die_usage
      local body='{"enabled":true}'
      [ "$sub" = "disable" ] && body='{"enabled":false}'
      # No skipTest either way: the server treats an enabled-only patch as a
      # state flip and does not dry-run it. So a broken source can still be
      # switched off, and one can be switched back on before its key is set.
      api PATCH "/api/connectors/$1" "$body"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt source_write "$BODY" ;;
    *) die_usage ;;
  esac
}

# Credentials are write-only: the API returns names and pinned hosts, never a
# secret, so there is no `cred show`.
cmd_cred() {
  local sub="${1:-list}"; [ $# -gt 0 ] && shift
  case "$sub" in
    list)
      [ $# -eq 0 ] || die_usage
      api GET /api/credentials
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt creds "$BODY" ;;
    set)
      [ $# -eq 3 ] || die_usage
      local body
      body=$(HOST="$2" SECRET="$3" python3 -c '
import json, os
print(json.dumps({"allowedHost": os.environ["HOST"], "secret": os.environ["SECRET"]}))')
      api PUT "/api/credentials/$1" "$body"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; fmt cred_set "$BODY" ;;
    rm)
      [ $# -eq 1 ] || die_usage
      api DELETE "/api/credentials/$1"
      if [ "$JSON_OUT" = 1 ]; then printf '%s\n' "$BODY"; api_ok_or_die; return; fi
      api_ok_or_die; echo "removed  $1" ;;
    *) die_usage ;;
  esac
}

if [ $# -eq 0 ]; then
  cmd_overview
  exit 0
fi

top="$1"; shift
case "$top" in
  pomo) cmd_pomo "$@" ;;
  todo) cmd_todo "$@" ;;
  source) cmd_source "$@" ;;
  cred) cmd_cred "$@" ;;
  -h|--help|help) die_usage ;;
  *) die_usage ;;
esac
